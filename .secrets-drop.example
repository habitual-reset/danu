# Copy this file to .secrets-drop and fill in values.
# Never commit .secrets-drop — it is gitignored.
#
#   cp .secrets-drop.example .secrets-drop
#
# Then open .secrets-drop in TextEdit, paste your keys, save.
# Tell the agent: "import my secrets drop file"
#
# The agent (or scripts/import-secrets.sh) will merge into .env and delete .secrets-drop.

OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_CONSOLIDATION_MODEL=gpt-4.1

# Optional — only if rotating Twilio credentials:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=