# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database (SQLite for MVP; swap for Postgres later)
DATABASE_URL=sqlite:///./data/danu.db

# Default tenant/user for single-user MVP
DEFAULT_TENANT_ID=default
DEFAULT_USER_ID=matt

# Phone allowlist: E.164 numbers comma-separated
ALLOWLIST_PHONES=+15555550100

# Twilio (Phase 2+)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Public URL Twilio calls (tunnel URL in dev, no trailing slash)
# Example: https://your-subdomain.ngrok-free.app
PUBLIC_WEBHOOK_BASE_URL=

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_CONSOLIDATION_MODEL=gpt-4.1-mini

# Voice hold experience (optional)
VOICE_HOLD_ENABLED=true
# VOICE_HOLD_MUSIC_URL=https://your-cdn.com/hold.mp3

# iPhone bridge (Phase 4)
IPHONE_BRIDGE_API_KEY=